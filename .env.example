# ---- ArvanCloud MCP server configuration ----
# Copy to ".env" and fill in your values. All variables are optional except
# ARVAN_API_KEY (required for any real API call).

# Machine-user access key created in the ArvanCloud panel
# (Settings -> Machine User / API keys). You may paste it with or without the
# leading "Apikey " prefix — the server normalises it.
ARVAN_API_KEY=

# API base URL (default: https://napi.arvancloud.ir). Use the .com host if needed.
# ARVAN_BASE_URL=https://napi.arvancloud.ir

# Default IaaS region so you don't have to pass it every time, e.g. ir-thr-c2.
# ARVAN_DEFAULT_REGION=ir-thr-c2

# Comma-separated tool groups to expose, or "all" (default). "common" is always on.
# Options: common,compute,network,storage,objectstorage,cdn,dns,vod,live,
#          ssh,provision,k8s,net,iac,security,git
# ARVAN_ENABLED_SERVICES=all

# HTTP client tuning
# ARVAN_TIMEOUT=60
# ARVAN_MAX_RETRIES=4
# ARVAN_BACKOFF_FACTOR=1.0
# ARVAN_VERIFY_SSL=true

# Transport: stdio (default, for Claude Desktop / local), sse, or streamable-http.
# ARVAN_TRANSPORT=stdio
# ARVAN_HOST=0.0.0.0
# ARVAN_PORT=8000

# Horizontal scaling for the HTTP transport (many replicas behind a load
# balancer, no session affinity). Recommended for Kubernetes/HPA deployments.
# ARVAN_STATELESS_HTTP=true
# ARVAN_JSON_RESPONSE=true

# Timeout (seconds) for IaC/security/k8s validation subprocesses.
# ARVAN_IAC_TIMEOUT=120

# ---- Background tasks & scheduling ----
# Default webhook to POST task-completion status to (per-task override available).
# ARVAN_TASK_WEBHOOK=https://hooks.example.com/mcp-tasks
# ARVAN_TASK_MAX_CONCURRENCY=20
# ARVAN_TASK_MAX_TASKS=1000

# ---- Guardrails ----
# Expose only read-only tools (and restrict arvan_request to GET/HEAD).
# ARVAN_READ_ONLY=false
# Restrict the toolset (comma-separated globs). ALLOW wins as a whitelist.
# ARVAN_TOOLS_ALLOW=arvan_list_*,arvan_get_*
# ARVAN_TOOLS_DENY=arvan_delete_*,arvan_iac_terraform_destroy
# Per-minute tool-call rate limit (0 = unlimited).
# ARVAN_RATE_LIMIT=0

# ---- Notifications (optional defaults; can also be passed per-call) ----
# SLACK_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# ARVAN_SMTP_HOST=
# ARVAN_SMTP_PORT=587
# ARVAN_SMTP_USER=
# ARVAN_SMTP_PASSWORD=
# ARVAN_SMTP_FROM=

# ---- Object Storage (S3-compatible) ----
# Separate credentials from the API key — find them in the Object Storage panel.
# ARVAN_S3_ACCESS_KEY=
# ARVAN_S3_SECRET_KEY=
# Region selects the endpoint https://s3.<region>.arvanstorage.ir
# ARVAN_S3_REGION=ir-thr-at1
# ...or set the endpoint explicitly:
# ARVAN_S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir

# ---- SSH (remote exec into your servers) ----
# ARVAN_SSH_USER=root
# One of: inline key, key file, or password.
# ARVAN_SSH_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
# ARVAN_SSH_KEY_FILE=/path/to/id_ed25519
# ARVAN_SSH_PASSWORD=
# ARVAN_SSH_PORT=22
# Host-key verification is off by default (fresh servers). Point at a file to enforce:
# ARVAN_SSH_KNOWN_HOSTS=/path/to/known_hosts
# ARVAN_SSH_TIMEOUT=30
